# Pandora matchmaker 生产配置【模板】。cp matchmaker-prod.yaml.example matchmaker-prod.yaml 填真值后部署。
# ⚠️ 真实 matchmaker-prod.yaml 被 services/.gitignore 忽略,只提交本 .example。
# 与 dev 差异:删 enable_reflection;timeout 收紧;redis 加密码;kafka 真实 brokers;
#            服务间地址走 k8s service DNS;jwt 强随机 secret(与 login/envoy/hub_allocator 一致)。

server:
  grpc:
    network: tcp
    addr: ":50011"
    # 普通玩家 RPC 上限。ConfirmMatch 只持久 CAS ALLOCATING；AllocateBattle 由服务生命周期
    # durable worker 使用独立有界 ctx 推进，不能继承玩家断线/请求取消。
    timeout: "22s"
    # enable_reflection 不写 = false
  http:
    network: tcp
    addr: ":51011"

node:
  node_id: 1
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"
    db: 0
    dial_timeout: "2s"
    read_timeout: "1s"
    write_timeout: "1s"

kafka:
  brokers: ["__KAFKA_BROKER_1__:9092", "__KAFKA_BROKER_2__:9092"]
  dial_timeout: "2s"
  write_timeout: "5s"
  idempotent: true

snowflake:
  epoch: 1773446400
  node_bits: 17
  step_bits: 15

match:
  team_addr: "team.pandora.svc.cluster.local:50010"
  ds_allocator_addr: "ds-allocator.pandora.svc.cluster.local:50020"
  hub_allocator_addr: "hub-allocator.pandora.svc.cluster.local:50021"
  locator_addr: "player-locator.pandora.svc.cluster.local:50006"
  # 生产由 PANDORA_PLACEMENT_MATCH_START_SECRET 优先覆盖；禁止提交真实密钥。
  placement_match_start_proof_secret: "replace-via-pandora-config-secret-min-32-bytes"
  # 独立 Login→Matchmaker 服务身份 key；不得复用 JWT / DS callback / placement key。
  match_resume_auth_secret: "__MATCH_RESUME_AUTH_SECRET_32B__"
  match_resume_auth_audience: "matchmaker:5v5_ranked"
  allocation_abort_auth_secret: "__ALLOCATION_ABORT_AUTH_SECRET_32B__"
  allocation_abort_auth_audience: "ds-allocator:battle-allocation-abort"
  # liveness_gate_enabled: locator 在线判定两道门(队列扫死票 livenessSweep + 成局最终门 findOfflineMembers)。
  # ❗ 前提：UE Hub DS 心跳捎带 player_ids 续期 locator HUB 位置，且 hub_allocator 必须配 locator_addr
  # (转发续期的必经一环)，否则在线玩家 30s 后会被误判离线、扫掉排队票据。
  # 2026-07-08 dev 实机联调 + 端到端验收通过后默认开启；回归异常(在线玩家 locator TTL 单调掉 0)先关此开关再排查。
  liveness_gate_enabled: true
  map_id: 1
  game_mode: "5v5_ranked"
  confirm_timeout: "15s"
  match_interval: "2s"
  ticket_ttl: "30m" # 仅显式终态后的留存；非终态 ticket/claim 持久
  match_ttl: "30m"  # 仅显式终态后的留存；非终态 match 持久
  team_size: 5
  mmr_base_window: 200
  mmr_widen_per_sec: 20
  mmr_max_window: 2000
  optimistic_retry: 3

jwt:
  issuer: "pandora-login"
  audience: "pandora-client"
  # ⚠️ 必须与 login / envoy / hub_allocator 完全一致;≥32 字节强随机
  secret: "__JWT_SHARED_SECRET_32B_CHANGE_ME__"
  session_ttl: "24h"
  ds_ticket_ttl: "5m"
