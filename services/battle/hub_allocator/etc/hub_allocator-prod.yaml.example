# Pandora hub_allocator 生产配置【模板】。cp hub_allocator-prod.yaml.example hub_allocator-prod.yaml 填真值后部署。
# ⚠️ 真实 hub_allocator-prod.yaml 被 services/.gitignore 忽略,只提交本 .example。
# 与 dev 差异:删 enable_reflection;timeout 收紧;redis 加密码;jwt 强随机 secret(与 login/envoy/matchmaker 一致);
#            agones.enabled: true(接真 Agones Hub Fleet,不再用 Mock)。

server:
  grpc:
    network: tcp
    addr: ":50021"
    timeout: "5s"
    # enable_reflection 不写 = false
  http:
    network: tcp
    addr: ":51021"

node:
  node_id: 1
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"
    db: 0
    dial_timeout: "2s"
    read_timeout: "1s"
    write_timeout: "1s"

jwt:
  issuer: "pandora-login"
  audience: "pandora-client"
  # ⚠️ 必须与 login / envoy / matchmaker 完全一致;≥32 字节强随机
  secret: "__JWT_SHARED_SECRET_32B_CHANGE_ME__"
  session_ttl: "24h"
  ds_ticket_ttl: "5m"

# kafka producer:发布 pandora.hub.migrate 强制整合迁移通知(push 订阅)。
# brokers 为空 + consolidation_enabled=true 时迁移仅靠 Hub DS drain 心跳兜底(无无缝推送)。
kafka:
  brokers: ["kafka:9092"]
  dial_timeout: "2s"
  write_timeout: "5s"
  idempotent: true

hub:
  heartbeat_timeout: "30s"        # 不变量 §4:Hub 默认 30s;Battle DS 仍为 15s
  sweep_interval: "5s"
  shard_ttl: "30m"
  assignment_ttl: "30m"
  reservation_ttl: "3m15s"      # >= DSTicket TTL + 15s，且 <= assignment_ttl
  default_region: "global"
  default_capacity: 500           # 大厅 500 人/实例
  # autoscale_enabled / consolidation_enabled 仅在 agones.enabled=true(下方,真 Fleet scaler)时生效。
  autoscale_enabled: true         # 开启 Hub Fleet 自动扩缩容
  players_per_hub: 500            # >500 自动扩到新大厅(ceil(total/500))
  min_replicas: 1                 # 开服默认大厅副本数(可配置)
  max_replicas: 50                # 大厅副本上限(按容量预算调整)
  consolidation_enabled: true     # 强制整合:低负载时搬迁玩家排空分片后缩容(需 kafka 推送无缝倒计时)
  migrate_grace_seconds: 30       # 迁移优雅倒计时(秒) + 缩容回收最短等待
  consolidation_batch: 50         # 单 tick 每分片最多迁移人数(防撑死)
  optimistic_retry: 3
  # locator_addr: player_locator gRPC 地址。两个用途：①玩家切线护栏(战斗/匹配中禁切)；
  # ②在线保活链必经一环：Hub DS 心跳捎带 player_ids → 本服务转发 locator 续期 HUB 位置 TTL。
  # ⚠️ matchmaker 开了 liveness_gate_enabled 时此项不可留空，否则在线玩家 30s 后被误判离线、扫掉排队票据。
  locator_addr: "player-locator.pandora.svc.cluster.local:50006"

  # prod 用真 Agones(下方 agones.enabled: true),不再需要 mock_* 字段

# 生产接真 Agones Hub Fleet 发现。in-cluster 运行时 api_server/token_path/ca_path 留空用默认。
agones:
  enabled: true
  # api_server: 留空 = in-cluster "https://kubernetes.default.svc"
  namespace: "default"
  fleet_name: "pandora-hub"
  insecure_skip_tls_verify: false
  list_timeout: "5s"

# 会话现行性门(R5 复审 P0-1,INC-20260722-004):生产强制档,顶号后旧 JWT 立即失效;
# 权威端点漏配拒启,权威不可达 fail-closed。与 gen_cluster_config.ps1 -Prod 产物一致。
#
# require_ticket_sjti(R7 收口;R9 复审 P0-1 改为默认开启,安全默认 fail-closed):
# 全新部署(全 fleet 均为本版本)保持 true——顶号后旧设备残票在 Hub 入场确认点作废。
# 只有「从不带 sjti 的旧版本升级」才按 docs/design/session-generation-rollout.md 阶段序
# 临时置 false(兼容档:空 sjti 告警放行),待全 fleet Hub DS 已转发 sjti、旧 DS 排空、
# 并等满一个票据最大 TTL 后,尽快改回 true 滚动重启收口。
# 升级期提前置 true = 旧 DS 上所有玩家无法进入大厅。
session_gate:
  require: true
  require_ticket_sjti: true
