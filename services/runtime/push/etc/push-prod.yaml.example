# Pandora push 生产配置【模板】。cp push-prod.yaml.example push-prod.yaml 填真值后部署。
# ⚠️ 真实 push-prod.yaml 被 services/.gitignore 忽略,只提交本 .example。
# 与 dev 差异:删 enable_reflection;redis 加密码;kafka 真实 brokers。

server:
  grpc:
    network: tcp
    addr: ":50014"
    # enable_reflection 不写 = false
  http:
    network: tcp
    addr: ":51014"

node:
  node_id: 1
  session_expire_min: 1440
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"
    db: 0
    dial_timeout: "2s"

kafka:
  brokers: ["__KAFKA_BROKER_1__:9092", "__KAFKA_BROKER_2__:9092"]
  group_id: "pandora-push"
  partition_cnt: 4
  dial_timeout: "2s"
  read_timeout: "10s"
  write_timeout: "10s"
  channel_buffer: 1024
  idempotent: true

snowflake:
  epoch: 1773446400
  node_bits: 17
  step_bits: 15

push:
  # topics 不填 = 走 kafkax.PushTopics 权威默认集合(新业务 topic 在 pkg/kafkax/topics.go
  # 里维护,push 无需改配置)。显式列出会覆盖默认且极易漏项——本模板曾漏
  # pandora.chat.guild / pandora.chat.group / pandora.guild.event / pandora.presence.update
  # 四个 topic(按旧模板部署对应事件完全不消费),故改为不列。
  # 如确需裁剪订阅面,列出时必须与 kafkax.PushTopics 全量核对。
  offline_cache_ttl: "5m"
  # 会话现行性门强制档(P0,INC-20260722-004;R6 复审开放缺口③,本模板补齐):
  # 生产必须 true——绕过 Envoy 直连服务且省略 JTI 时宽松档会放行建流。
  require_session_gate: true
