# Pandora player_locator 生产配置【模板】。cp locator-prod.yaml.example locator-prod.yaml 填真值后部署。
# ⚠️ 真实 locator-prod.yaml 被 services/.gitignore 忽略,只提交本 .example。
# 与 dev 差异:删 enable_reflection;timeout 收紧;redis 加密码 + 真实 host。

server:
  grpc:
    network: tcp
    addr: ":50006"
    timeout: "5s"
    # enable_reflection 不写 = false
  http:
    network: tcp
    addr: ":51006"

node:
  node_id: 1
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"
    db: 0
    dial_timeout: "2s"

snowflake:
  epoch: 1773446400
  node_bits: 17
  step_bits: 15

locator:
  location_ttl: "30s"             # 不变量 §1:玩家位置 30s heartbeat,SetLocation 刷 TTL
  # locator 是唯一 verifier，拿四把分权 key；各 writer 只拿自己的那一把。
  placement_account_bootstrap_proof_secret: "__PLACEMENT_ACCOUNT_BOOTSTRAP_SECRET_32B__"
  placement_match_start_proof_secret: "__PLACEMENT_MATCH_START_SECRET_32B__"
  placement_battle_exit_proof_secret: "__PLACEMENT_BATTLE_EXIT_SECRET_32B__"
  placement_hub_transfer_proof_secret: "__PLACEMENT_HUB_TRANSFER_SECRET_32B__"
  placement_battle_departure_proof_secret: "__PLACEMENT_BATTLE_DEPARTURE_SECRET_32B__"
