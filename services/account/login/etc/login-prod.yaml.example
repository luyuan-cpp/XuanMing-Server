# Pandora login 生产配置【模板】。
#
# 用法:cp login-prod.yaml.example login-prod.yaml,把所有 __占位符__ 换成真实值后部署。
#   pwsh tools/scripts/release_preflight.ps1   # 发布前校验本文件安全
# ⚠️ 真实 login-prod.yaml 已被 services/.gitignore 忽略,只提交本 .example。
# ⚠️ 配置加载用 Kratos file source(无 env 替换),secret 直接写在 yaml,故真值文件绝不入库。
#
# 与 dev 的关键差异:
#   - 删除 enable_reflection(零值 false = 关 gRPC reflection,防 schema 泄露)
#   - dev_skip_password: false(走 bcrypt 真密码校验)
#   - 删除所有 mock_*(不再用 mock hub/account)
#   - timeout 收紧;redis 加密码;mysql 强密码;jwt 强随机 secret

server:
  grpc:
    network: tcp
    addr: ":50001"
    timeout: "5s"                 # prod 收紧(dev 15s)
    enable_rate_limit: true       # 压测前审核门禁-A:BBR 自适应限流(dev 默认关,prod 必开),
                                  # 过载时按 CPU/inflight/RT 丢负载,防登录洪峰把副本压垮/OOM
    # enable_reflection 不写 = false:prod 关闭 reflection
  http:
    network: tcp
    addr: ":51001"

node:
  node_id: 1
  session_expire_min: 1440
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"   # prod 必须设 Redis 密码
    db: 0
    dial_timeout: "2s"
    # 压测前审核门禁-C:login 的 session/JTI 校验强依赖 Redis 且不可降级。显式配读写超时,
    # 把单命令最坏 socket 占用从 go-redis 默认 3s 降到 1s、更快 fail(与 matchmaker/battle 对齐);
    # 池参数消除 Redis 抖动下池耗尽拖垮登录的盲区(留空则沿用 10×GOMAXPROCS,事故中无法临时扩池)。
    read_timeout: "1s"
    write_timeout: "1s"
    pool_size: 100                   # 示例:按 CPU 核数×并发登录目标调整(建议引入 automaxprocs 使核数准确)
    min_idle_conns: 10
    pool_timeout: "2s"               # 取不到连接的最长等待(默认 read_timeout+1s),超时即快失败
  mysql_client:
    dsn: "pandora:__MYSQL_STRONG_PASSWORD__@tcp(__MYSQL_HOST__:3306)/pandora_account?parseTime=true&loc=UTC&charset=utf8mb4&collation=utf8mb4_0900_ai_ci"
    # 压测前审核门禁-B:按目标登录 QPS×单登录持连时长核定 max_open_conns(与 MySQL
    # max_connections 一起放大);单登录 4 次往返、PersistSessionJTI 事务持连+行锁最久。
    max_open_conns: 64               # 示例:登录风暴下按压测 DBStats.WaitCount/WaitDuration 调整
    max_idle_conns: 16
    conn_max_lifetime: "30m"
    conn_max_idle_time: "5m"         # 门禁-B:高并发登录回落期及时释放空闲连接(留空=不因空闲回收)
    ping_timeout: "3s"

snowflake:
  epoch: 1773446400
  node_bits: 17
  step_bits: 15

locker:
  account_lock_ttl: 10
  player_lock_ttl: 10

login:
  session_token_ttl: "24h"
  ds_ticket_ttl: "5m"               # 不变量 §3:DS 票据短时效
  # 滚动兼容默认 false；Activation Job 机械确认所有 writer 具备绑定能力后才改 true。
  # true 后 login 只接受 hub_allocator 权威签发且绑定 Redis 当前 assignment 的 hub 票。
  require_hub_assignment_binding: false
  # hub_assignment_fence: binding=true 时必填，使用与 DS auth 相同 required writer epoch。
  # 会话代际强制门(R7/R8 收口;R9 复审 P0-1 改为默认开启,安全默认 fail-closed,
  # 见 docs/design/session-generation-rollout.md):
  # 全新部署(迁移先行 + 全 fleet 均为本版本)保持 true——顶号后旧会话的 SetRole /
  # 无 sjti 票据在权威点被拒。只有「从不带会话代际的旧版本升级」才允许按 rollout
  # 文档的阶段序临时置 false,并在满足下列前提后尽快改回 true:
  #   session_generation_enforce: 激活前提 ① pandora_account 已跑 000003 迁移;
  #     ② 全 fleet login 已升级(emit 双写)且旧版本 Pod 排空;③ 等满一个会话
  #     TTL(session_ttl,默认 24h;或强制全量重登/清空会话)——旧版本 login 建立
  #     的会话不会写 MySQL 代际行,残留的陈旧行会误拒合法会话;④ 观察
  #     session_generation_persist_failed 为零。
  #   require_ticket_sjti: 激活前提 ① 全 fleet matchmaker/hub_allocator 签票必带 sjti
  #     且旧版本排空;② 等满一个票据最大 TTL(v2 RS256 上限 180s;legacy HS256 为
  #     ds_ticket_ttl,默认 5min);③ 观察 ticket_missing_session_binding_compat_allow
  #     日志为零。
  session_generation_enforce: true
  require_ticket_sjti: true
  dev_skip_password: false          # ⚠️ 必须 false:走正常 bcrypt 密码校验
  # 选角白名单(⚠️ prod 必填):对齐客户端 CfgMisc.DefaultRoleIDs(选角界面可选列表)。
  # 留空 = fail-closed,SelectRole 全部拒绝(dev_allow_any_role 默认 false,严禁上生产)。
  allowed_role_ids: [__ROLE_ID_1__, __ROLE_ID_2__]
  jwt:
    issuer: "pandora-login"
    audience: "pandora-client"
    # ⚠️ 必须与 envoy jwt_authn / matchmaker / hub_allocator 完全一致;≥32 字节强随机,不得用 dev 值
    secret: "__JWT_SHARED_SECRET_32B_CHANGE_ME__"
    session_ttl: "24h"
    ds_ticket_ttl: "5m"
  # 生产服务间地址走 k8s service DNS(按实际命名空间/service 名调整)
  locator:
    addr: "player-locator.pandora.svc.cluster.local:50006"
  hub:
    # P0#5:用 headless Service 的 dns:/// 端点(clusterIP:None,DNS 返回全部 Ready Pod IP)+
    # 客户端 round_robin(见 login main.go)。hub-allocator 是单写者,普通 ClusterIP 直连会被 L4
    # 钉在某一 Pod,落到非-writer 就永远拿可重试 UNAVAILABLE;dns:/// + round_robin 让 AssignHub
    # 就地重试每次轮到不同副本,滚动重叠(maxSurge 双 Pod)内数次命中当前 writer。
    # 前缀 dns:/// 不可省(缺则 gRPC 按 passthrough 单后端,LB 退化无效)。
    addr: "dns:///hub-allocator-headless.pandora.svc.cluster.local:50021"
  # matchmaker 只读权威兜底(P0 修复 2026-07-15,生产必配):locator presence 未命中 BATTLE
  # 时再查 ResolvePlayerMatchContext,防 READY↔投影窗口/租约蒸发把在局玩家误路由回 Hub。
  # auth_secret/auth_audience:login→matchmaker 内部服务鉴权(internalrpcauth)。
  # ⚠️ 必须与 matchmaker 的 match.match_resume_auth_secret/audience 完全一致;
  # ≥32 字节独立强随机密钥,不得复用玩家 JWT secret。缺失则被 matchmaker 拒绝,
  # B1 下等于战斗恢复链 fail-closed。
  matchmaker:
    addr: "matchmaker.pandora.svc.cluster.local:50011"
    auth_secret: "__MATCH_RESUME_AUTH_SECRET_32B_CHANGE_ME__"
    auth_audience: "matchmaker:5v5_ranked"
    region: ""

# 生产实际配置由 gen_cluster_config.ps1 原子注入 enforce/redis + fence；本模板保持
# off/legacy，避免脱离 Activation 流程手工填半套配置后误以为已启用在线入场权威。
ds_auth:
  mode: "off"
  authority_mode: "legacy"
  issuer: "pandora-ds-control"
  audience: "pandora-ds"
  secret: "__DS_JWT_SHARED_SECRET_32B_CHANGE_ME__"
  active_heartbeat_max_age: "30s"
