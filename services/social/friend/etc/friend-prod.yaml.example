# Pandora friend 服务生产配置模板(2026-06-15)。
#
# 真实部署时复制为 friend-prod.yaml 并按集群实际地址 / 密码填写,**不要提交真实密码到 git**。
# - gRPC :50004 / HTTP :51004(仅 /metrics)
# - prod: enable_reflection 不写(零值 false,关 reflection 减少攻击面)

server:
  grpc:
    network: tcp
    addr: ":50004"
    timeout: "3s"
  http:
    network: tcp
    addr: ":51004"

node:
  node_id: 1
  # Redis:会话现行性门只读 login 会话权威 pandora:sess(R5 复审 P0-1,共享实例)。
  redis_client:
    host: "redis:6379"
    db: 0
    dial_timeout: "2s"
  mysql_client:
    dsn: "pandora:__REPLACE_WITH_SECRET__@tcp(mysql:3306)/pandora_social?parseTime=true&loc=UTC&charset=utf8mb4&collation=utf8mb4_0900_ai_ci"
    max_open_conns: 64
    max_idle_conns: 16
    conn_max_lifetime: "30m"
    ping_timeout: "3s"

kafka:
  brokers: ["kafka:9092"]
  group_id: "pandora-friend"
  partition_cnt: 4

friend:
  max_friends: 200
  locator_addr: "player-locator:50006"

# 会话现行性门(R5 复审 P0-1,INC-20260722-004):生产强制档,顶号后旧 JWT 立即失效;
# 权威端点漏配拒启,权威不可达 fail-closed。与 gen_cluster_config.ps1 -Prod 产物一致。
session_gate:
  require: true
