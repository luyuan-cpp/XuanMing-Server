# ============================================================
# Pandora 后端仓库 .gitignore
# ============================================================

# Go 构建产物
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
bin/
build/
dist/
# configtable 发布产物必须入库(manifest+表体是部署契约;真实产物测试依赖干净检出即有文件,
# 审计 P1:上面的 dist/ 会把它一并忽略,这里显式放行)
!configtable/dist/
!configtable/dist/**

# Go module 本地缓存
vendor/
.gocache/

# 运行时产物
run/
logs/
*.log
*.pid

# 临时文件
tmp/
temp/
*.tmp
.tmp-*
*.bak
*.swp
*.swo
*~

# 环境变量
.env
.env.local
.env.*.local
*.env

# 数据库迁移凭据/真实 inventory（示例文件可入库，真值 bundle 必须留在仓库外或 run/）
*.dsn
tools/migrate/*.json
!tools/migrate/targets.example.json

# IDE / 编辑器
.vscode/
.idea/
.vs/
*.iml
.fleet/

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# Coverage / 测试
*.coverprofile
coverage.out
coverage.html

# 协议生成产物(强制走 buf gen,不入库可选 — 这里入库便于客户端直接消费)
# proto/gen/ — 暂时入库,如需排除取消注释

# 压测产物(robot 下的 logs/ 已经在上面 logs/ 通配里)
robot/logs/

# k8s 本地配置
deploy/k8s/local/
*.kubeconfig

# Docker 本地数据卷
deploy/data/

# 镜像 tar 是构建产物,一律不入库(2026-07-23 起走制品目录分发,见 docs/design/release-pipeline.md;
# 旧的 pandora-images.tar 入库属过渡方案,已退役)
deploy/offline-images/*.tar

# 制品库本地根目录(若把制品根指到仓库内,兜底不入库)
artifacts/

# 第三方下载缓存
third_party/_cache/

# 私钥 / 证书
*.pem
*.key
*.crt
*.p12
secrets/
