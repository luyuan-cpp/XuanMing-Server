# Pandora 本地开发环境样例。
# 首次使用:Copy-Item deploy/env/dev.env.example deploy/env/dev.env
# dev.env 被 git 忽略；真实 webhook/token/密码只写 dev.env，不要提交。

MYSQL_ROOT_PASSWORD=pandora_dev_root
MYSQL_USER=pandora
MYSQL_PASSWORD=pandora_dev_pwd
GRAFANA_USER=admin
GRAFANA_PASSWORD=pandora_dev_admin

# 群渠道可选；留空时 Grafana 不生成对应 receiver。飞书 URL 应指向已验证的转换 relay。
PANDORA_ALERT_WECOM_URL=
PANDORA_ALERT_FEISHU_WEBHOOK=

# ntfy v2.11 inline template 会从 Grafana JSON 提取 title/message。
PANDORA_ALERT_NTFY_URL=http://ntfy:80/pandora-alerts?tpl=1&t=%7B%7B.title%7D%7D&m=%7B%7B.message%7D%7D
PANDORA_NTFY_BASE_URL=http://127.0.0.1:8080
# 手机局域网联调时才改 0.0.0.0，同时把 BASE_URL 改为开发机局域网地址。
PANDORA_NTFY_BIND_HOST=127.0.0.1

PANDORA_EDGE_BIND_HOST=127.0.0.1
